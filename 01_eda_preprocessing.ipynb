   "source": [
    "---\n",
    "# 📦 COMMIT 1 — Load Data\n",
    "> **Git message:** `feat(data): load PRDECT-ID raw dataset and validate schema`"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1.1 Baca CSV"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_raw = pd.read_csv(RAW_PATH, sep=\";\", encoding=\"utf-8\")\n",
    "\n",
    "print(f\"✅ Dataset berhasil dibaca.\")\n",
    "print(f\"   Baris    : {df_raw.shape[0]:,}\")\n",
    "print(f\"   Kolom    : {df_raw.shape[1]}\")\n",
    "print(f\"   Kolom    : {df_raw.columns.tolist()}\")\n",
    "df_raw.head(5)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1.2 Tipe Data & Schema"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Ringkasan schema\n",
    "schema = pd.DataFrame({\n",
    "    \"dtype\"      : df_raw.dtypes,\n",
    "    \"non_null\"   : df_raw.notna().sum(),\n",
    "    \"null\"       : df_raw.isna().sum(),\n",
    "    \"null_%\"     : (df_raw.isna().sum() / len(df_raw) * 100).round(2),\n",
    "    \"unique\"     : df_raw.nunique(),\n",
    "    \"sample\"     : df_raw.iloc[0]\n",
    "})\n",
    "schema"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1.3 Cek Missing Values"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "missing = df_raw.isnull().sum()\n",
    "missing_pct = (missing / len(df_raw) * 100).round(2)\n",
    "\n",
    "missing_df = pd.DataFrame({\"Count\": missing, \"Percentage (%)\": missing_pct})\n",
    "missing_df = missing_df[missing_df[\"Count\"] > 0]\n",
    "\n",
    "if missing_df.empty:\n",
    "    print(\"✅ Tidak ada missing values.\")\n",
    "else:\n",
    "    print(f\"⚠️  Ditemukan missing values pada {len(missing_df)} kolom:\")\n",
    "    display(missing_df)\n",
    "\n",
    "# Tampilkan baris dengan missing\n",
    "df_raw[df_raw.isnull().any(axis=1)]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1.4 Cek Duplikat"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "n_dup = df_raw.duplicated().sum()\n",
    "n_dup_review = df_raw.duplicated(subset=[\"Customer Review\"]).sum()\n",
    "\n",
    "print(f\"Duplikat full-row       : {n_dup}\")\n",
    "print(f\"Duplikat 'Customer Review': {n_dup_review}\")\n",
    "\n",
    "if n_dup > 0:\n",
    "    print(\"\\nContoh duplikat:\")\n",
    "    display(df_raw[df_raw.duplicated(keep=False)].sort_values(\"Customer Review\").head(10))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1.5 Working Copy — Drop Missing & Duplikat"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = df_raw.copy()\n",
    "\n",
    "# Drop baris dimana label target NaN\n",
    "df.dropna(subset=[\"Sentiment\", \"Emotion\", \"Customer Review\"], inplace=True)\n",
    "\n",
    "# Drop full-row duplikat\n",
    "df.drop_duplicates(inplace=True)\n",
    "df.reset_index(drop=True, inplace=True)\n",
    "\n",
    "print(f\"Shape setelah cleaning awal : {df.shape}\")\n",
    "print(f\"Baris dihapus               : {len(df_raw) - len(df)}\")"
   ]
  },
