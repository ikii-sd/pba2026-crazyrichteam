    "    \"kalo\"    : \"kalau\",    \"klw\"     : \"kalau\",    \"kmrn\"    : \"kemarin\",\n",
    "    \"skrg\"    : \"sekarang\", \"bsk\"     : \"besok\",    \"dll\"     : \"dan lain lain\",\n",
    "    \"dsb\"     : \"dan sebagainya\",\n",
    "\n",
    "    # ── Kata sifat & kualitas produk ─────────────────────────────────────────\n",
