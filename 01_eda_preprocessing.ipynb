    "axes[0].set_ylim(0, sent_counts.max() * 1.2)\n",
    "axes[0].tick_params(axis=\"x\", labelsize=11)\n",
    "\n",
    "# ── Emosi ───────────────────────────────────────────────────────────────────\n",
