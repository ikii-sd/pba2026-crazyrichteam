    "    \"karna\"   : \"karena\",   \"krena\"   : \"karena\",   \"sm\"      : \"sama\",\n",
    "    \"jg\"      : \"juga\",     \"juga\"    : \"juga\",     \"tp\"      : \"tapi\",\n",
