    "    \"udh\"     : \"sudah\",    \"sdh\"     : \"sudah\",    \"dah\"     : \"sudah\",\n",
    "    \"emg\"     : \"memang\",   \"emang\"   : \"memang\",   \"hrs\"     : \"harus\",\n",
    "    \"bs\"      : \"bisa\",     \"bsa\"     : \"bisa\",     \"bgt\"     : \"banget\",\n",
    "    \"bngt\"    : \"banget\",   \"bener\"   : \"benar\",    \"bner\"    : \"benar\",\n",
    "    \"aja\"     : \"saja\",     \"doang\"   : \"saja\",     \"dong\"    : \"lah\",\n",
    "    \"sih\"     : \"\",         \"deh\"     : \"\",         \"kok\"     : \"\",\n",
    "\n",
    "    # ── Kata ganti & preposisi ───────────────────────────────────────────────\n",
    "    \"yg\"      : \"yang\",     \"yng\"     : \"yang\",     \"dr\"      : \"dari\",\n",
