    "    axes[0].text(bar.get_x() + bar.get_width()/2, bar.get_height() + 15,\n",
    "                 f\"{val:,}\\n({pct:.1f}%)\", ha=\"center\", va=\"bottom\", fontsize=10)\n",
    "axes[0].set_title(\"Sentimen\", fontsize=12)\n",
